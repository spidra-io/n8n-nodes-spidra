{
  "name": "n8n-nodes-spidra",
  "version": "0.1.0",
  "description": "Official Spidra nodes for n8n - scrape, batch scrape, and crawl websites with AI",
  "license": "MIT",
  "author": {
    "name": "Spidra",
    "url": "https://spidra.io"
  },
  "homepage": "https://github.com/spidra-io/n8n-nodes-spidra",
  "repository": {
    "type": "git",
    "url": "https://github.com/spidra-io/n8n-nodes-spidra.git"
  },
  "keywords": [
    "n8n-community-node-package"
  ],
  "main": "index.js",
  "scripts": {
    "build": "tsc && cp nodes/Spidra/spidra.svg dist/nodes/Spidra/spidra.svg",
    "dev": "tsc --watch"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SpidraApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Spidra/Spidra.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "n8n-workflow": "^1",
    "typescript": "^5"
  }
}
